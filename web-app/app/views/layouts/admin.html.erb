<% chrome = Admin::DomainNav.chrome_for(current_domain) %>
<!DOCTYPE html>
<html lang="en" data-theme="<%= chrome[:theme] %>">
<head>
  <title><%= content_for?(:title) ? yield(:title) : "Admin" %> - <%= chrome[:title] %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <% if chrome[:favicon_dir] %>
    <%= favicon_link_tag "#{chrome[:favicon_dir]}/favicon.ico" %>
    <link rel="icon" type="image/png" href="<%= image_path("#{chrome[:favicon_dir]}/favicon-96x96.png") %>" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="<%= image_path("#{chrome[:favicon_dir]}/favicon.svg") %>" />
    <link rel="apple-touch-icon" sizes="180x180" href="<%= image_path("#{chrome[:favicon_dir]}/apple-touch-icon.png") %>" />
    <meta name="apple-mobile-web-app-title" content="Admin - <%= chrome[:title] %>" />
  <% end %>

  <%= stylesheet_link_tag chrome[:stylesheet], "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload" %>

  <script>
    window.addEventListener('auth:signout', function() {
      window.location.href = '/';
    });
  </script>
</head>
<body class="bg-base-200" data-controller="authentication">
  <div class="drawer lg:drawer-open">
    <input id="admin-drawer" type="checkbox" class="drawer-toggle" />

    <!-- Main content -->
    <div class="drawer-content flex flex-col">
      <%= render "admin/shared/navbar" %>

      <div id="flash" class="mx-4 mt-4">
        <%= render "admin/shared/flash" if flash.any? %>
      </div>

      <main class="flex-1 p-6">
        <%= yield %>
      </main>
    </div>

    <!-- Sidebar -->
    <div class="drawer-side z-40">
      <label for="admin-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
      <%= render "admin/shared/sidebar" %>
    </div>
  </div>
</body>
</html>
