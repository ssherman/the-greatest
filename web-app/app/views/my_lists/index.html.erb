<% content_for :page_title, "My Lists" %>

<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">My Lists</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-testid="my-lists-dashboard">
    <% @user_lists.each do |list| %>
      <%= render UserLists::Dashboard::ListCardComponent.new(
            user_list: list,
            item_count: @item_counts.fetch(list.id, 0)
          ) %>
    <% end %>
  </div>
</div>
